{
  "id": "project-has-no-tasks",
  "testPlanId": "9e9ec7d8-f59e-44a9-8d5b-09dfd5ed0724",
  "requirementId": "9c8be9e7-f156-4f22-82ae-658db10b84f4",
  "suiteName": "Start Project Task - Salesforce PSA",
  "case": {
    "id": "project-has-no-tasks",
    "title": "Project with no Project Tasks shows appropriate message",
    "priority": "P2",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Test data: Project 'QA - No Tasks Project' exists with zero Project Tasks."
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Salesforce PSA Home",
        "value": "https://ukgsf--stest.sandbox.lightning.force.com/lightning/page/home"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Global search input is visible on Home page",
        "locatorHint": "input[placeholder='Search...']",
        "value": "10000"
      },
      {
        "id": "s3",
        "action": "fill",
        "targetDescription": "Enter 'QA - No Tasks Project' in global search",
        "locatorHint": "input[placeholder='Search...']",
        "value": "QA - No Tasks Project"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "Search results dropdown list is visible",
        "locatorHint": "ul[role='listbox']",
        "value": "10000"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Select 'QA - No Tasks Project' from results",
        "locatorHint": "ul[role='listbox'] li:has-text('QA - No Tasks Project')"
      },
      {
        "id": "s6",
        "action": "waitForVisible",
        "targetDescription": "Project detail header is visible",
        "locatorHint": "h1.slds-page-header__title, lightning-formatted-text.recordTitle",
        "value": "10000"
      },
      {
        "id": "s7",
        "action": "tap",
        "targetDescription": "Open Project Tasks related list",
        "locatorHint": "a[title='Project Tasks'], a:has-text('Project Tasks')"
      },
      {
        "id": "s8",
        "action": "waitForVisible",
        "targetDescription": "Project Tasks related list region is visible",
        "locatorHint": "div[role='region'][aria-label='Project Tasks'], h2:has-text('Project Tasks')",
        "value": "10000"
      },
      {
        "id": "s9",
        "action": "assertVisible",
        "targetDescription": "No items message is displayed for Project Tasks",
        "locatorHint": "div:has-text('No items to display'), div:has-text('No records to display'), div:has-text('No Project Tasks found')"
      }
    ],
    "tags": [
      "@e2e",
      "@regression"
    ]
  }
}
