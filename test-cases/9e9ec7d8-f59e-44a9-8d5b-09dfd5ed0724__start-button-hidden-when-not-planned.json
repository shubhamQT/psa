{
  "id": "start-button-hidden-when-not-planned",
  "testPlanId": "9e9ec7d8-f59e-44a9-8d5b-09dfd5ed0724",
  "requirementId": "9c8be9e7-f156-4f22-82ae-658db10b84f4",
  "suiteName": "Start Project Task - Salesforce PSA",
  "case": {
    "id": "start-button-hidden-when-not-planned",
    "title": "Start button is not available when task status is not Planned",
    "priority": "P2",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Test data: Project 'QA - In Progress Task Project' exists.",
      "Project has a task named 'Task In Progress' with status Started (not Planned)."
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Salesforce PSA Home",
        "value": "https://ukgsf--stest.sandbox.lightning.force.com/lightning/page/home"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Global search input is visible on Home page",
        "locatorHint": "input[placeholder='Search...']",
        "value": "10000"
      },
      {
        "id": "s3",
        "action": "fill",
        "targetDescription": "Enter 'QA - In Progress Task Project' in global search",
        "locatorHint": "input[placeholder='Search...']",
        "value": "QA - In Progress Task Project"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "Search results dropdown list is visible",
        "locatorHint": "ul[role='listbox']",
        "value": "10000"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Select 'QA - In Progress Task Project' from results",
        "locatorHint": "ul[role='listbox'] li:has-text('QA - In Progress Task Project')"
      },
      {
        "id": "s6",
        "action": "waitForVisible",
        "targetDescription": "Project detail header is visible",
        "locatorHint": "h1.slds-page-header__title, lightning-formatted-text.recordTitle",
        "value": "10000"
      },
      {
        "id": "s7",
        "action": "tap",
        "targetDescription": "Open Project Tasks related list",
        "locatorHint": "a[title='Project Tasks'], a:has-text('Project Tasks')"
      },
      {
        "id": "s8",
        "action": "waitForVisible",
        "targetDescription": "Project Tasks list is visible",
        "locatorHint": "div[role='region'][aria-label='Project Tasks'], h2:has-text('Project Tasks')",
        "value": "10000"
      },
      {
        "id": "s9",
        "action": "tap",
        "targetDescription": "Open 'Task In Progress' from list",
        "locatorHint": "table tr:has(td:has-text('Task In Progress')) a[role='link'], table tr:has(td:has-text('Task In Progress')) a"
      },
      {
        "id": "s10",
        "action": "waitForVisible",
        "targetDescription": "Task detail header is visible",
        "locatorHint": "h1.slds-page-header__title, lightning-formatted-text.recordTitle",
        "value": "10000"
      },
      {
        "id": "s11",
        "action": "assertContainsText",
        "targetDescription": "Task status is not Planned (should be Started)",
        "locatorHint": ".slds-form-element:has(label:has-text('Status')) lightning-formatted-text, .slds-form-element:has(label:has-text('Status')) .slds-form-element__static",
        "assertion": "Started"
      },
      {
        "id": "s12",
        "action": "assertHidden",
        "targetDescription": "Start button is not visible when task not Planned",
        "locatorHint": "button:has-text('Start')"
      }
    ],
    "tags": [
      "@e2e",
      "@regression"
    ]
  }
}
